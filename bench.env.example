DO_TOKEN=
DO_REGION=sgp1
DO_SIZE=s-4vcpu-8gb
DO_IMAGE=ubuntu-24-04-x64
DO_ENABLE_MONITORING=true
DO_SSH_KEY_FINGERPRINT=

BENCH_SSH_PRIVATE_KEY=~/.ssh/id_rsa
BENCH_SSH_USER=root
# Optional: reuse existing host as k6 load driver (skip bench-driver droplet create)
BENCH_DRIVER_IP=
# Optional: use local machine as k6 load driver (also skips bench-driver create)
BENCH_DRIVER_LOCAL=false

# Optional. If empty, scripts use a timestamp.
BENCH_RUN_ID=

# Optional. If empty, scripts use local k3s-learn HEAD SHA.
K3S_LEARN_REF=

# Variant A: coraza-envoy-waf (ext_proc) image by digest/tag.
BENCH_WAF_IMAGE=ghcr.io/ilyasaftr/coraza-envoy-waf:latest

# Variant B: coraza-envoy-go-filter integration hook.
# This command runs on sut-go-filter after base stack install.
# Keep it idempotent.
# Default hook is a placeholder that records parity deltas.
# Replace with your real install command before production A/B runs.
BENCH_GOFILTER_INSTALL_CMD='bash /root/k3s-learn/scripts/bench/hooks/install_go_filter_variant.sh'

# Selector for go-filter benchmark component resource sampling.
# For in-process Envoy Go filter this should be the Envoy pod selector.
BENCH_GOFILTER_RESOURCE_SELECTOR=app.kubernetes.io/name=envoy

# Benchmark profile
# fast-dev is the default quick loop; full restores the slower publication-grade path.
BENCH_MODE=fast-dev
# Optional overrides. Leave unset to use the BENCH_MODE preset.
# BENCH_SCENARIOS="10"
# BENCH_REPEATS=1
BENCH_VUS=100
# BENCH_DURATION=20s
# BENCH_WARMUP=3
# BENCH_COOLDOWN=2
BENCH_ATTACK_RATE=0.02
BENCH_INFO_RATE=0.08
BENCH_WAF_MESSAGE_TIMEOUT=750ms
BENCH_WAF_NUM_STREAM_WORKERS=0
BENCH_WAF_REQUEST_BODY_MODE=Buffered
BENCH_WAF_RESPONSE_BODY_MODE=None
