{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "enable": true,
        "expr": "ALERTS{alertstate=\"firing\", namespace=\"$namespace\"}",
        "hide": false,
        "iconColor": "red",
        "name": "Firing Alerts",
        "step": "60s",
        "titleFormat": "Firing {{alertname}}",
        "textFormat": "namespace={{namespace}} severity={{severity}}",
        "type": "query"
      }
    ]
  },
  "description": "Per-app dashboard organized around the Google SRE monitoring guidance: symptom-first golden signals for user impact, followed by minimal white-box capacity context to explain why the app is degrading.",
  "editable": true,
  "links": [
    {
      "icon": "external link",
      "title": "Envoy",
      "tooltip": "Go to the upstream Envoy dashboard",
      "type": "link",
      "url": "/d/heHhNSFf6Na8vIZWRs8H",
      "targetBlank": false
    }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 100,
      "panels": [],
      "title": "Symptoms (Four Golden Signals)",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "User-facing traffic routed through Envoy Gateway to this app. This is the first symptom signal from the Google SRE model.",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "id": 101,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(rate(envoy_cluster_upstream_rq_total{job=\"envoy-gateway-proxy\",envoy_cluster_name=~\"^httproute/${namespace}/${app}/rule/0$\"}[$__rate_interval]))",
          "legendFormat": "traffic",
          "refId": "A"
        }
      ],
      "title": "Traffic (req/s)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Server-side failures seen by callers. This is the high-signal error symptom for this app path.",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "id": 102,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "(100 * sum(rate(envoy_cluster_upstream_rq_total{job=\"envoy-gateway-proxy\",envoy_cluster_name=~\"^httproute/${namespace}/${app}/rule/0$\",envoy_response_code=~\"5..\"}[$__rate_interval])) / clamp_min(sum(rate(envoy_cluster_upstream_rq_total{job=\"envoy-gateway-proxy\",envoy_cluster_name=~\"^httproute/${namespace}/${app}/rule/0$\"}[$__rate_interval])), 0.001)) or on() vector(0)",
          "legendFormat": "5xx %",
          "refId": "A"
        }
      ],
      "title": "Error Rate (5xx %)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Tail latency for upstream requests. Tail latency is the user-visible latency signal emphasized in the SRE guidance.",
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 300
              },
              {
                "color": "red",
                "value": 1000
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "id": 103,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "1000 * histogram_quantile(0.95, sum(rate(envoy_cluster_upstream_rq_time_bucket{job=\"envoy-gateway-proxy\",envoy_cluster_name=~\"^httproute/${namespace}/${app}/rule/0$\"}[$__rate_interval])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "title": "Latency p95 (ms)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Saturation is app-specific. For this lab, the useful saturation signals are CPU throttling and memory pressure against configured limits; the panel shows the worse of the two.",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "id": 104,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "max(((100 * sum(rate(container_cpu_cfs_throttled_periods_total{namespace=\"$namespace\",pod=~\"$app-.*\",container!=\"POD\"}[$__rate_interval])) / clamp_min(sum(rate(container_cpu_cfs_periods_total{namespace=\"$namespace\",pod=~\"$app-.*\",container!=\"POD\"}[$__rate_interval])), 1)) or on() vector(0)) or ((100 * sum(container_memory_working_set_bytes{namespace=\"$namespace\",pod=~\"$app-.*\",container!=\"POD\"}) / clamp_min(sum(kube_pod_container_resource_limits{namespace=\"$namespace\",pod=~\"$app-.*\",resource=\"memory\"}), 1)) or on() vector(0)))",
          "legendFormat": "worst saturation %",
          "refId": "A"
        }
      ],
      "title": "Saturation (CPU or Memory %)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "id": 200,
      "panels": [],
      "title": "Symptom Trends",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Traffic should be broken down by response code class so you can distinguish normal load from client and server-side failure patterns.",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "gradientMode": "opacity",
            "spanNulls": true,
            "showPoints": "never",
            "lineInterpolation": "smooth"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "min",
            "max",
            "mean",
            "lastNotNull"
          ]
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "id": 201,
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(rate(envoy_cluster_upstream_rq_total{job=\"envoy-gateway-proxy\",envoy_cluster_name=~\"^httproute/${namespace}/${app}/rule/0$\"}[$__rate_interval]))",
          "legendFormat": "total",
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "sum(rate(envoy_cluster_upstream_rq_total{job=\"envoy-gateway-proxy\",envoy_cluster_name=~\"^httproute/${namespace}/${app}/rule/0$\",envoy_response_code=~\"2..\"}[$__rate_interval])) or on() vector(0)",
          "legendFormat": "2xx",
          "refId": "B"
        },
        {
          "editorMode": "code",
          "expr": "sum(rate(envoy_cluster_upstream_rq_total{job=\"envoy-gateway-proxy\",envoy_cluster_name=~\"^httproute/${namespace}/${app}/rule/0$\",envoy_response_code=~\"4..\"}[$__rate_interval])) or on() vector(0)",
          "legendFormat": "4xx",
          "refId": "C"
        },
        {
          "editorMode": "code",
          "expr": "sum(rate(envoy_cluster_upstream_rq_total{job=\"envoy-gateway-proxy\",envoy_cluster_name=~\"^httproute/${namespace}/${app}/rule/0$\",envoy_response_code=~\"5..\"}[$__rate_interval])) or on() vector(0)",
          "legendFormat": "5xx",
          "refId": "D"
        }
      ],
      "title": "Request Volume by Response Class",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "The SRE guidance recommends monitoring all HTTP response classes even when only some are alert-worthy. This separates caller mistakes from server failures.",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "gradientMode": "opacity",
            "spanNulls": true,
            "showPoints": "never",
            "lineInterpolation": "smooth"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "min",
            "max",
            "mean",
            "lastNotNull"
          ]
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "id": 202,
      "targets": [
        {
          "editorMode": "code",
          "expr": "(100 * sum(rate(envoy_cluster_upstream_rq_total{job=\"envoy-gateway-proxy\",envoy_cluster_name=~\"^httproute/${namespace}/${app}/rule/0$\",envoy_response_code=~\"4..\"}[$__rate_interval])) / clamp_min(sum(rate(envoy_cluster_upstream_rq_total{job=\"envoy-gateway-proxy\",envoy_cluster_name=~\"^httproute/${namespace}/${app}/rule/0$\"}[$__rate_interval])), 0.001)) or on() vector(0)",
          "legendFormat": "4xx %",
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "(100 * sum(rate(envoy_cluster_upstream_rq_total{job=\"envoy-gateway-proxy\",envoy_cluster_name=~\"^httproute/${namespace}/${app}/rule/0$\",envoy_response_code=~\"5..\"}[$__rate_interval])) / clamp_min(sum(rate(envoy_cluster_upstream_rq_total{job=\"envoy-gateway-proxy\",envoy_cluster_name=~\"^httproute/${namespace}/${app}/rule/0$\"}[$__rate_interval])), 0.001)) or on() vector(0)",
          "legendFormat": "5xx %",
          "refId": "B"
        }
      ],
      "title": "Error Ratio by Response Class",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Tail latency should be graphed explicitly. p50 explains normal behavior; p95 and p99 show user pain during degradation.",
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "gradientMode": "opacity",
            "spanNulls": true,
            "showPoints": "never",
            "lineInterpolation": "smooth"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "min",
            "max",
            "mean",
            "lastNotNull"
          ]
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 14
      },
      "id": 203,
      "targets": [
        {
          "editorMode": "code",
          "expr": "1000 * histogram_quantile(0.50, sum(rate(envoy_cluster_upstream_rq_time_bucket{job=\"envoy-gateway-proxy\",envoy_cluster_name=~\"^httproute/${namespace}/${app}/rule/0$\"}[$__rate_interval])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "1000 * histogram_quantile(0.95, sum(rate(envoy_cluster_upstream_rq_time_bucket{job=\"envoy-gateway-proxy\",envoy_cluster_name=~\"^httproute/${namespace}/${app}/rule/0$\"}[$__rate_interval])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "editorMode": "code",
          "expr": "1000 * histogram_quantile(0.99, sum(rate(envoy_cluster_upstream_rq_time_bucket{job=\"envoy-gateway-proxy\",envoy_cluster_name=~\"^httproute/${namespace}/${app}/rule/0$\"}[$__rate_interval])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "title": "Latency Distribution (p50 / p95 / p99)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Saturation should reflect the resource that actually constrains the app. Here that is CPU throttling and memory pressure; disk I/O is intentionally excluded because this podinfo workload is not storage-bound.",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "gradientMode": "opacity",
            "spanNulls": true,
            "showPoints": "never",
            "lineInterpolation": "smooth"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "min",
            "max",
            "mean",
            "lastNotNull"
          ]
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 14
      },
      "id": 204,
      "targets": [
        {
          "editorMode": "code",
          "expr": "(100 * sum(rate(container_cpu_cfs_throttled_periods_total{namespace=\"$namespace\",pod=~\"$app-.*\",container!=\"POD\"}[$__rate_interval])) / clamp_min(sum(rate(container_cpu_cfs_periods_total{namespace=\"$namespace\",pod=~\"$app-.*\",container!=\"POD\"}[$__rate_interval])), 1)) or on() vector(0)",
          "legendFormat": "cpu throttle %",
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "(100 * sum(container_memory_working_set_bytes{namespace=\"$namespace\",pod=~\"$app-.*\",container!=\"POD\"}) / clamp_min(sum(kube_pod_container_resource_limits{namespace=\"$namespace\",pod=~\"$app-.*\",resource=\"memory\"}), 1)) or on() vector(0)",
          "legendFormat": "memory pressure %",
          "refId": "B"
        }
      ],
      "title": "Saturation Trend (CPU Throttle / Memory Pressure %)",
