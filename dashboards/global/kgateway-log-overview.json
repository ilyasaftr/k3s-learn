{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Gateway access-log view redesigned for the kgateway OTel stack. Uses OTLP-to-Loki labels emitted by Envoy access logs instead of pod-text log parsing.",
  "editable": true,
  "graphTooltip": 0,
  "links": [
    {
      "icon": "external link",
      "title": "Envoy",
      "tooltip": "Go to the upstream Envoy gateway dashboard",
      "type": "link",
      "url": "/d/kgateway-envoy",
      "targetBlank": false
    },
    {
      "icon": "external link",
      "title": "Kgateway Operations",
      "tooltip": "Go to the upstream kgateway operations dashboard",
      "type": "link",
      "url": "/d/kgateway-operations",
      "targetBlank": false
    },
    {
      "icon": "external link",
      "title": "App Observability Template",
      "tooltip": "Drill into an app-specific RED dashboard",
      "type": "link",
      "url": "/d/app-observability-template",
      "targetBlank": false
    }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 100,
      "title": "Gateway OTLP Logs",
      "type": "row"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "description": "Total gateway access-log records written to Loki in the selected time range.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "id": 101,
      "options": {
        "reduceOptions": {
          "calcs": [
            "sum"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(count_over_time({service_name=\"shared-gateway.kgateway-system\"}[$__range]))",
          "legendFormat": "gateway access logs",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Access Logs",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "description": "Number of active gateway access-log streams in the selected time range. This replaces the old trace-id-only stat because trace_id is not filterable as a Loki stream selector in the current OTLP ingestion path.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "id": 102,
      "options": {
        "reduceOptions": {
          "calcs": [
            "sum"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "count(sum by (stream) (count_over_time({service_name=\"shared-gateway.kgateway-system\"}[5m])))",
          "legendFormat": "active streams",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Active Access Streams",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "description": "How many Envoy upstream clusters are represented in the access-log stream for the selected time range.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "id": 103,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "count(sum by (cluster_name) (count_over_time({service_name=\"shared-gateway.kgateway-system\"}[5m])))",
          "legendFormat": "clusters",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Active Envoy Clusters",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "description": "How many gateway nodes are emitting access logs right now.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "id": 104,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "count(sum by (node_name) (count_over_time({service_name=\"shared-gateway.kgateway-system\"}[5m])))",
          "legendFormat": "nodes",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Active Gateway Nodes",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "id": 200,
      "title": "Traffic Distribution",
      "type": "row"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "description": "Top Envoy upstream clusters in the access-log stream. This is the most useful volume breakdown for the OTLP log model.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "gradientMode": "opacity",
            "spanNulls": true,
            "showPoints": "never",
            "lineInterpolation": "smooth"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "id": 201,
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "sum",
            "max",
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "topk(10, sum by (cluster_name) (count_over_time({service_name=\"shared-gateway.kgateway-system\"}[5m])))",
          "legendFormat": "{{cluster_name}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Access Logs by Envoy Cluster",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "description": "Access-log volume grouped by the node_name label emitted by the gateway access log pipeline.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "gradientMode": "opacity",
            "spanNulls": true,
            "showPoints": "never",
            "lineInterpolation": "smooth"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "id": 202,
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "sum",
            "max",
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "topk(10, sum by (node_name) (count_over_time({service_name=\"shared-gateway.kgateway-system\"}[5m])))",
          "legendFormat": "{{node_name}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Access Logs by Node",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "id": 300,
      "title": "Trace Correlation",
      "type": "row"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "description": "Gateway access-log rate over time from the working Loki selector. This replaces the old trace-id filtered panel because trace_id is not filterable as a stream selector here.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "spanNulls": true,
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "thresholdsStyle": {
              "mode": "line+area"
            }
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 15
      },
      "id": 301,
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "sum",
            "max",
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(count_over_time({service_name=\"shared-gateway.kgateway-system\"}[5m]))",
          "legendFormat": "access logs",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Gateway Access Logs Over Time",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "description": "Recent gateway access-log records. The log line body can be empty for Envoy OTLP access logs, so keep labels visible and inspect fields like trace_id, span_id, cluster_name, and node_name.",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 15
      },
      "id": 302,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "{service_name=\"shared-gateway.kgateway-system\"}",
          "legendFormat": "",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Recent Gateway Access Records",
      "type": "logs"
    }
  ],
